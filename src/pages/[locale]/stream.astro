---
import Layout from "../../layouts/Layout.astro";
import { translations } from "../../translations";
import { getRelativeLocaleUrl } from "astro:i18n";

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'es' } }
  ];
}

const { locale } = Astro.params;
const t = translations[locale as keyof typeof translations];

// Helper to simulate slow async data sources
const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
---
<Layout title={t.stream.title} locale={locale}>
  <h1>{t.stream.title}</h1>
  <p>{t.stream.description}</p>

  <section class="stream-section">
    <h2>⚡ {t.stream.instant}</h2>
    <p>{t.stream.instantDesc}</p>
  </section>

  {async () => {
    await sleep(1000);
    return (
      <section class="stream-section">
        <h2>📦 {t.stream.userData}</h2>
        <p>{t.stream.userDataDesc}</p>
        <pre>{JSON.stringify({ id: 1, name: "Alice", role: "admin" }, null, 2)}</pre>
      </section>
    );
  }}

  {async () => {
    await sleep(2000);
    return (
      <section class="stream-section">
        <h2>📊 {t.stream.analytics}</h2>
        <p>{t.stream.analyticsDesc}</p>
        <pre>{JSON.stringify({ views: 12483, sessions: 3201, bounceRate: "32%" }, null, 2)}</pre>
      </section>
    );
  }}

  {async () => {
    await sleep(1500);
    return (
      <section class="stream-section">
        <h2>🌐 {t.stream.externalApi}</h2>
        <p>{t.stream.externalApiDesc}</p>
        <pre>{JSON.stringify({ status: "healthy", latency: "42ms", region: "us-east-1" }, null, 2)}</pre>
      </section>
    );
  }}
</Layout>

<style>
  .stream-section {
    background: var(--color-surface);
    border: 1px solid #334155;
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-top: 1.5rem;
  }

  .stream-section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
</style>
